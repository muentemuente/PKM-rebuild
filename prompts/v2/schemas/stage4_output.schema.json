{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage4FrontmatterDraft",
  "description": "Pydantic-Source-of-Truth: pipeline/schemas.py FrontmatterDraft",
  "type": "object",
  "required": [
    "title", "slug", "summary", "type", "doc_role", "category",
    "sources_docs", "source_chunks", "status", "review_status", "confidence",
    "doc_version", "created", "updated", "last_synthesized", "prompt_version"
  ],
  "properties": {
    "title": {"type": "string"},
    "slug": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "type": {"type": "string", "enum": ["process-document", "knowledge-article", "compact-reference"]},
    "doc_role": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "category": {"type": "string"},
    "subcategory": {"type": ["string", "null"]},
    "tags": {"type": "array", "items": {"type": "string"}},
    "related": {"type": "array", "items": {"type": "string"}},
    "used_in": {"type": "array", "items": {"type": "string"}},
    "parent_concept": {"type": ["string", "null"]},
    "child_concepts": {"type": "array", "items": {"type": "string"}},
    "sources_docs": {"type": "array", "items": {"type": "string"}},
    "source_chunks": {"type": "array", "items": {"type": "string"}},
    "merged_from": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string", "enum": ["draft", "review", "stable", "deprecated"]},
    "review_status": {"type": "string", "enum": ["ai_drafted", "human_reviewed", "verified"]},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "doc_version": {"type": "string"},
    "created": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "updated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "last_synthesized": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "prompt_version": {"type": "string"},
    "keyphrases": {"type": "array", "items": {"type": "string"}},
    "key_points": {"type": "array", "items": {"type": "string"}},
    "open_questions": {"type": "array", "items": {"type": "string"}},
    "next_steps": {"type": "array", "items": {"type": "string"}}
  }
}
